{
  "name": "fin-plan",
  "version": "0.1.2",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "docker:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:restart": "docker-compose -f docker-compose.dev.yml restart",
    "docker:build": "docker-compose -f docker-compose.dev.yml build",
    "docker:clean": "docker-compose -f docker-compose.dev.yml down -v",
    "start": "docker-compose -f docker-compose.dev.yml up -d && echo \"🚀 All services started! Frontend: http://localhost:3000 | Backend: http://localhost:3001\"",
    "stop": "docker-compose -f docker-compose.dev.yml down && echo \"✅ All services stopped!\"",
    "restart": "bun run stop && bun run start",
    "db:migrate": "docker-compose -f docker-compose.dev.yml exec backend bun run db:migrate",
    "db:seed": "docker-compose -f docker-compose.dev.yml exec backend bun run db:seed",
    "db:studio": "cd apps/backend && bun run db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "bun-types": "^1.3.11",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "turbo": "^2.9.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "overrides": {
    "ws": "^8.17.1",
    "flatted": "^3.4.0",
    "brace-expansion": "^1.1.13",
    "picomatch": "^2.3.2",
    "@babel/runtime": "^7.26.10",
    "qs": "^6.14.2",
    "rollup": "^4.59.0"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": false,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "arrowParens": "always",
    "endOfLine": "lf"
  }
}
