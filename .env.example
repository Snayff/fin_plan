# Repo-root .env.example
#
# These variables are interpolated by the production docker-compose.yml.
# For local development, prefer `bun run start` — it uses docker-compose.dev.yml
# which has hardcoded dev values and does not read this file.
#
# Copy to `.env` and fill values if you need to invoke `docker compose` directly
# from the repo root (e.g. `docker compose ps`, `docker compose logs`) and want
# to silence "variable is not set" warnings, or if you're testing the prod
# compose locally before deploying.
#
# In production (Coolify), these are provided as environment secrets — do NOT
# commit a populated .env file.

DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=change-me-min-32-chars
JWT_REFRESH_SECRET=change-me-min-32-chars
COOKIE_SECRET=change-me-min-32-chars
CSRF_SECRET=change-me-min-32-chars
CORS_ORIGIN=https://your-frontend-host
